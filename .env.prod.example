# docu-store — Production Environment Configuration
#
# Copy to .env.prod and fill in secrets:
#   cp .env.prod.example .env.prod
#
# Deployment (two stacks):
#   1. docker stack deploy -c docker-compose.infra.yml docu-store-infra
#   2. docker stack deploy -c docker-compose.prod.yml docu-store
#
# This file is read by docker-compose.prod.yml via env_file.
# Service DNS names (mongo, kafka, temporal, etc.) are set in the compose
# environment block — you do NOT need to set connection URIs here.

# ── Application ─────────────────────────────────────────────
APP_NAME=DocuStore
APP_ENV=production
LOG_LEVEL=INFO

# ── Ports (host-side, customizable) ────────────────────────
API_PORT=8000
WEB_PORT=15000
# ESDB_PORT=2113
# TEMPORAL_PORT=7233
# QDRANT_PORT=6333
# TEMPORAL_UI_PORT=8233
# KAFKA_UI_PORT=5051
# QDRANT_UI_PORT=6334

# ── Image version (default: latest) ────────────────────────
# VERSION=0.1.0

# ── Temporal Postgres ───────────────────────────────────────
# Generate: openssl rand -base64 24
TEMPORAL_POSTGRES_PASSWORD=

# ── Temporal Concurrency ────────────────────────────────────
# Increase for production hardware. Ollama LLM: keep at 1-2. Cloud API: 5-10.
TEMPORAL_MAX_CONCURRENT_ACTIVITIES=5
TEMPORAL_MAX_CONCURRENT_LLM_ACTIVITIES=2

# ── Sentinel Auth ───────────────────────────────────────────
SENTINEL_URL=https://sentinel.example.com
# Generate from Sentinel admin panel
SENTINEL_SERVICE_KEY=
SENTINEL_SERVICE_NAME=docu-store
SENTINEL_IDP_JWKS_URL=https://www.googleapis.com/oauth2/v3/certs

# ── LLM Provider ───────────────────────────────────────────
# Options: ollama, openai, gemini
LLM_PROVIDER=ollama
LLM_MODEL_NAME=gemma3:27b
LLM_BASE_URL=http://ollama:11434
# LLM_API_KEY=                   # required for openai/gemini

# Chat LLM (optional override — defaults to batch LLM settings)
# CHAT_LLM_PROVIDER=
# CHAT_LLM_MODEL_NAME=
# CHAT_LLM_BASE_URL=
# CHAT_LLM_API_KEY=

# ── Blob Storage ────────────────────────────────────────────
# Local filesystem (mount a volume to /data/blobs)
BLOB_BASE_URL=file:///data/blobs
# S3: BLOB_BASE_URL=s3://your-bucket/docu-store

# ── Qdrant Cloud (optional — default uses local Qdrant) ────
# QDRANT_API_KEY=

# ── Langfuse (LLM Observability — infra stack) ─────────────
# These are used by the app to connect to Langfuse.
PROMPT_REPOSITORY_TYPE=langfuse
LANGFUSE_HOST=http://langfuse-web:3000
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=

# ── Langfuse Infrastructure (infra stack internal) ─────────
# Generate passwords: openssl rand -base64 24
LANGFUSE_PG_PASSWORD=
LANGFUSE_CLICKHOUSE_PASSWORD=
LANGFUSE_MINIO_PASSWORD=
LANGFUSE_REDIS_PASSWORD=
# Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
LANGFUSE_NEXTAUTH_SECRET=
LANGFUSE_SALT=
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
LANGFUSE_ENCRYPTION_KEY=
# Langfuse admin user (pre-seeded on first start)
LANGFUSE_ADMIN_EMAIL=admin@example.com
LANGFUSE_ADMIN_NAME=admin
LANGFUSE_ADMIN_PASSWORD=
# LANGFUSE_URL=https://langfuse.example.com
# LANGFUSE_PORT=3000

# ── Umami (Web Analytics — infra stack) ────────────────────
# Generate: openssl rand -base64 24
UMAMI_PG_PASSWORD=
# UMAMI_PORT=3001
# UMAMI_TRACKER_SCRIPT=ds-analytics

# ── Embeddings ──────────────────────────────────────────────
# Device is forced to cpu in compose environment block.
# Override model names only if using different embedding models.
# EMBEDDING_MODEL_NAME=nomic-ai/nomic-embed-text-v1.5
# EMBEDDING_DIMENSIONS=768
# SMILES_EMBEDDING_MODEL_NAME=DeepChem/ChemBERTa-77M-MTR

# ── Plugins (optional) ─────────────────────────────────────
# Comma-separated list of plugin package names
# ENABLED_PLUGINS=

# ── Frontend Build Args (used at image build time, not runtime) ──
# These are passed as --build-arg when building sidxz/docu-store-web.
# NEXT_PUBLIC_API_URL=https://api.example.com
# NEXT_PUBLIC_APP_URL=https://app.example.com
# NEXT_PUBLIC_SENTINEL_URL=https://sentinel.example.com
# NEXT_PUBLIC_GOOGLE_CLIENT_ID=
# NEXT_PUBLIC_GITHUB_CLIENT_ID=
