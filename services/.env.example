# Application
APP_NAME=DocuStore
APP_ENV=development
LOG_LEVEL=INFO

# EventStoreDB
EVENTSTOREDB_URI=esdb://localhost:2113?tls=false

# Kafka
ENABLE_EXTERNAL_EVENT_STREAMING=true
KAFKA_BOOTSTRAP_SERVERS=localhost:19092
KAFKA_TOPIC=docu_store_events

# API
API_HOST=0.0.0.0
API_PORT=8000

# LLM Configuration
# LLM_PROVIDER=ollama                     # Provider: ollama | openai | anthropic | gemini
# LLM_MODEL_NAME=gemma4:31b               # Default. gemma4 supports native tool calling + structured output.
#                                         # Older local models (e.g. gemma3:27b) do NOT support native tools —
#                                         # if you switch to one, also set CHAT_AGENT_TOOL_CALLING_MODE=react.
# CHAT_AGENT_TOOL_CALLING_MODE=auto       # auto|native|react. auto=native for all providers; react for models w/o native tools.
# OPENAI_API_KEY=sk-...                  # when LLM_PROVIDER=openai
# ANTHROPIC_API_KEY=sk-ant-...           # when LLM_PROVIDER=anthropic
# GOOGLE_API_KEY=...                     # when LLM_PROVIDER=gemini
# ALLOW_CLOUD_LLM=true                   # set false for confidential deploys (local Ollama only)
# LLM_REASONING=off                      # off | low | medium | high (batch LLM reasoning/thinking)
# CHAT_LLM_REASONING=off                 # off | low | medium | high (chat LLM reasoning/thinking)

# MongoDB Read Models
MONGO_URI=mongodb://localhost:27017/?replicaSet=rs0
MONGO_DB=docu_store
MONGO_PAGES_COLLECTION=page_read_models
MONGO_ARTIFACTS_COLLECTION=artifact_read_models
MONGO_TRACKING_COLLECTION=read_model_tracking
MONGO_TAG_DICTIONARY_COLLECTION=tag_dictionary

# Temporal
TEMPORAL_ADDRESS=localhost:7233

# Qdrant Vector Store
QDRANT_URL=http://localhost:6333
# QDRANT_API_KEY=your-api-key-for-cloud  # Uncomment for cloud deployment
QDRANT_COLLECTION_NAME=page_embeddings
QDRANT_COMPOUND_COLLECTION_NAME=compound_embeddings
QDRANT_SUMMARY_COLLECTION_NAME=summary_embeddings

# Embeddings (dense)
EMBEDDING_MODEL_PROVIDER=sentence-transformers  # Options: sentence-transformers, openai
EMBEDDING_MODEL_NAME=nomic-ai/nomic-embed-text-v1.5
EMBEDDING_DIMENSIONS=768  # Must match model (768 for nomic, 384 for MiniLM)
EMBEDDING_DEVICE=cpu  # Options: cpu, cuda, mps (for Mac M1/M2)
EMBEDDING_QUERY_PREFIX=search_query:   # Asymmetric prefix for queries (nomic requires this)
EMBEDDING_DOCUMENT_PREFIX=search_document:   # Asymmetric prefix for documents
# OPENAI_API_KEY=sk-...  # Only needed if EMBEDDING_MODEL_PROVIDER=openai

# SMILES / ChemBERTa embeddings
SMILES_EMBEDDING_MODEL_NAME=DeepChem/ChemBERTa-77M-MTR
SMILES_EMBEDDING_DEVICE=cpu

# Cross-encoder reranker (Stage 2 — rescores retrieval candidates)
RERANKER_ENABLED=true
RERANKER_MODEL_NAME=cross-encoder/ms-marco-MiniLM-L-12-v2
RERANKER_DEVICE=cpu

# Text chunking
CHUNK_SIZE=1000  # Characters per chunk (~200-250 tokens)
CHUNK_OVERLAP=200  # Overlap between chunks to preserve context

# NER extraction
NER_MAX_CHAR_BUFFER=5000  # Max chars per LLM chunk. Higher = fewer LLM calls (default 5000)

# HuggingFace model cache (defaults to ~/.cache/huggingface)
# Set to a stable path to avoid re-downloading models on fresh environments.
# HF_HOME=/path/to/cache
